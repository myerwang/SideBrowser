thod.run","when":"sf:project_opened && sf:has_cached_test_method && sf:has_target_org"},{"command":"sf.apex.test.run","when":"sf:project_opened && sf:has_target_org"},{"command":"sf.apex.test.suite.run","when":"sf:project_opened && sf:has_target_org"},{"command":"sf.apex.test.suite.create","when":"sf:project_opened && sf:has_target_org"},{"command":"sf.apex.test.suite.add","when":"sf:project_opened && sf:has_target_org"},{"command":"sf.apex.test.openOrgOnlyTest","when":"false"},{"command":"sf.apex.test.refresh","when":"false"},{"command":"sf.apex.testing.walkthrough.open","when":"sf:project_opened"}]},"commands":[{"command":"sf.apex.test.run","title":"SFDX: Run Apex Tests"},{"command":"sf.apex.test.suite.run","title":"SFDX: Run Apex Test Suite"},{"command":"sf.apex.test.suite.create","title":"SFDX: Create Apex Test Suite"},{"command":"sf.apex.test.suite.add","title":"SFDX: Add Tests to Apex Test Suite"},{"command":"sf.apex.test.last.class.run","title":"SFDX: Re-Run Last Run Apex Test Class"},{"command":"sf.apex.test.class.run","title":"SFDX: Run Apex Test Class"},{"command":"sf.apex.test.method.run","title":"SFDX: Run Apex Test Method"},{"command":"sf.apex.test.last.method.run","title":"SFDX: Re-Run Last Run Apex Test Method"},{"command":"sf.apex.test.openOrgOnlyTest","title":"Open in Virtual Editor"},{"command":"sf.apex.test.refresh","title":"SFDX: Refresh Apex Tests"},{"command":"sf.apex.testing.walkthrough.open","title":"SFDX: Open Apex Test Explorer Walkthrough","category":"Apex Testing"}],"viewsWelcome":[{"view":"workbench.view.testing","contents":"Note: If you have Apex tests in your workspace and they don't appear in the Test Explorer, make sure they are deployed to your default org."}],"walkthroughs":[{"id":"sf.apex.testing.explorer","title":"Apex Test Explorer","description":"Browse tests from your org, run classes or single methods, use test suites, filter the tree, and read results in the Test Results panel.","when":"sf:project_opened","steps":[{"id":"discover-org-tests","title":"See tests available in the org","description":"Open the **Testing** view (flask icon in the Activity Bar). Under **Apex Tests**, the extension lists test classes and methods from your default org (namespaces, packages, then classes). Authorize a default org if the tree is empty.\n\n[Open Testing view](command:workbench.view.extension.test)","media":{"image":"images/walkthrough/view-tests.png","altText":"Test Explorer showing Apex Test Suites, namespaces, and test classes expanded with methods."},"completionEvents":["onCommand:workbench.view.extension.test"]},{"id":"run-class-method","title":"Run a test class or a single method","description":"Expand a class and use **Run Test** on the **class** row to run every `@IsTest` method in that class. Expand one level further and use **Run Test** on a **method** row to run only that test. **Debug Test** works the same way (org-only tests cannot be debugged).","media":{"image":"images/walkthrough/run-tests.gif","altText":"Same Test Explorer view highlighting classes and test methods you can run or debug from the tree."}},{"id":"test-suites","title":"View and run Apex test suites","description":"At the top of **Apex Tests**, open **Apex Test Suites**. Expand a suite once to load its classes, then **Run Test** on the suite. You can also use **SFDX: Run Apex Test Suite** from the Command Palette.","media":{"image":"images/walkthrough/view-test-suites.png","altText":"Apex Test Suites expanded with a suite and member test classes, with run and debug actions."}},{"id":"filter-tests","title":"Filter by tag, text, or exclude (!)","description":"Use the filter box on the Testing view: type text to match names, `@in-workspace` / `@org-only` / `@test-suite` for tags, and prefix with `!` to exclude matches. The main **Run** action runs in-workspace tests (or everything visible when a filter is applied). Choose **Run All Tests in Org** from the run profile dropdown to run the entire org.","media":{"image":"images/walkthrough/filter-tests.gif","altText":"Filter field filtering tests by text with matching test methods shown in the tree."}},{"id":"test-results","title":"See results in the Test Results tab","description":"After a run, the tree shows pass/fail; expand failures for details. Open the **Test Results** panel for the full output. Enable **salesforcedx-vscode-apex-testing.test-run-concise** if you want the UI to emphasize failures.","media":{"image":"images/walkthrough/view-test-results.png","altText":"Test Results panel with coverage tables, summary, and Apex Testing sidebar listing passed tests."}}]}],"configuration":{"type":"object","title":"Salesforce Apex Testing Configuration","properties":{"salesforcedx-vscode-apex-testing.test-run-concise":{"type":"boolean","default":false,"description":"Display only failed test results."},"salesforcedx-vscode-apex-testing.outputFormat":{"type":"string","enum":["markdown","text"],"default":"markdown","description":"Format for test result reports. Markdown provides rich formatting with tables and code blocks. Text provides plain text output for minimal environments.","enumDescriptions":["Markdown format with tables, code blocks, and rich formatting (default)","Plain text format for minimal environments"]},"salesforcedx-vscode-apex-testing.testSortOrder":{"type":"string","enum":["runtime","coverage","severity"],"default":"runtime","description":"Sort order for test results in reports. Runtime sorts by execution time (slowest first), Coverage sorts by code coverage (lowest first), Severity sorts by combined issues (worst first).","enumDescriptions":["Sort by runtime - slowest tests first (default)","Sort by coverage - lowest coverage first","Sort by severity - tests with both poor performance and poor coverage first"]},"salesforcedx-vscode-apex-testing.testPerformanceThresholdMs":{"type":"number","default":5000,"description":"Performance threshold in milliseconds. Tests taking longer than this threshold will be highlighted as poorly performing. Default is 5000ms (5 seconds).","minimum":0},"salesforcedx-vscode-apex-testing.testCoverageThresholdPercent":{"type":"number","default":75,"description":"Coverage threshold as a percentage. Tests with coverage below this threshold will be highlighted as poorly covered. Default is 75%.","minimum":0,"maximum":100},"salesforcedx-vscode-apex-testing.retrieve-test-code-coverage":{"type":"boolean","default":false,"description":"Specifies whether code coverage results are calculated and retrieved when you run Apex tests."},"salesforcedx-vscode-apex-testing.disable-warnings-for-missing-coverage":{"type":"boolean","default":false,"description":"Disable UI warning when Apex test coverage is missing."}}}}},"location":{"$mid":1,"path":"/c:/Users/89961/.vscode/extensions/salesforce.salesforcedx-vscode-apex-testing-66.5.2","scheme":"file"},"isBuiltin":false,"targetPlatform":"undefined","publisherDisplayName":"Salesforce","metadata":{"isApplicationScoped":false,"isMachineScoped":false,"isBuiltin":false,"installedTimestamp":1775797119732,"pinned":false,"source":"gallery","id":"51b6af66-33e5-4d8e-bd9d-87e00ba3a8b8","publisherId":"656b996d-3c70-47b4-937e-e77c013faeea","publisherDisplayName":"Salesforce","targetPlatform":"undefined","updated":true,"private":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":false,"preRelease":false,"size":10756782},"isValid":true,"validations":[],"preRelease":false},{"type":1,"identifier":{"id":"salesforce.salesforcedx-vscode-services","uuid":"f4404beb-110d-4c74-9c83-10e10b1069f0"},"manifest":{"name":"salesforcedx-vscode-services","displayName":"Salesforce Services","description":"a shared services extension for other extensions to use","qna":"https://github.com/forcedotcom/salesforcedx-vscode/issues","bugs":{"url":"https://github.com/forcedotcom/salesforcedx-vscode/issues"},"repository":{"url":"https://github.com/forcedotcom/salesforcedx-vscode"},"icon":"images/VSCodeBundle.png","galleryBanner":{"color":"#ECECEC","theme":"light"