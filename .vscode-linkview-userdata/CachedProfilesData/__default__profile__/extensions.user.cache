f:has_target_org"},{"command":"sf.data.query.explain.selection","when":"sf:project_opened && editorHasSelection && sf:has_target_org"},{"command":"sf.data.query.explain.document","when":"sf:project_opened && resourceExtname == .soql && sf:has_target_org"}],"editor/title":[{"when":"resourceExtname == .soql","command":"soql.builder.toggle","group":"navigation"}]},"configuration":{"type":"object","title":"Salesforce SOQL Configuration","properties":{"salesforcedx-vscode-soql.experimental.validateQueries":{"type":"boolean","default":false,"description":"Use REST API to validate SOQL queries and to identify errors."}}},"walkthroughs":[{"id":"soqlWalkthrough","title":"Get Started with SOQL","description":"Learn how to build and run SOQL queries using the visual SOQL Builder in VS Code.","steps":[{"id":"step1","title":"Introduction to SOQL","description":"SOQL (Salesforce Object Query Language) is a powerful query language similar to SQL that allows you to search your organization's Salesforce data. The SOQL Builder provides a visual interface to create queries without writing SQL syntax manually.","media":{"image":"images/SOQL_Builder_50.16.0.gif","altText":"Introduction to SOQL Builder interface"}},{"id":"step2","title":"Create a New SOQL Query","description":"Start by creating a new SOQL query file. You can use the command palette and search for 'SFDX: Create Query in SOQL Builder' or use the button below to get started.\n\n⚠️ **Important**: Make sure you have authorized a Salesforce org and set it as your default org before proceeding. You can do this by running 'SFDX: Authorize an Org' from the command palette.\n\n[Create SOQL Query](command:soql.open.new.builder)","media":{"image":"images/SOQL_Builder_50.16.0.gif","altText":"Creating a new SOQL query"},"completionEvents":["onCommand:soql.open.new.builder"]},{"id":"step3","title":"Build Your Query Visually","description":"Use the visual SOQL Builder to construct your query by selecting objects, fields, and conditions. The builder provides an intuitive interface with dropdowns for available objects and fields from your org.\n\n🎯 **Get started**: Try selecting the `Account` object, then add fields like `Id`, `Name`, and `Type`. You can add filters in the WHERE section to narrow your results.","media":{"image":"images/SOQL_Builder_50.16.0.gif","altText":"Building a query in the SOQL Builder"}},{"id":"step4","title":"Run and View Results","description":"Execute your SOQL query by clicking the **Run Query** button in the SOQL Builder. The results will appear in a new tab showing your data in a tabular format. The results viewer allows you to browse through your data and understand the structure of your query results.","media":{"image":"images/SOQL_Builder_50.16.0.gif","altText":"Running a SOQL query and viewing results"}},{"id":"step5","title":"Save and Export Results","description":"After running a query, you can export the results by clicking the **Save** button in the results viewer. Choose between CSV or JSON format for further analysis. You can also save your SOQL queries as `.soql` files to reuse them later.\n\n💡 **Pro tip**: CSV format is great for spreadsheet analysis, while JSON format preserves data relationships for programmatic use.","media":{"image":"images/SOQL_Builder_50.16.0.gif","altText":"Saving and exporting SOQL query results"}}]}]},"activationEvents":["onLanguage:soql"]},"location":{"$mid":1,"path":"/c:/Users/89961/.vscode/extensions/salesforce.salesforcedx-vscode-soql-66.5.2","scheme":"file"},"isBuiltin":false,"targetPlatform":"undefined","publisherDisplayName":"Salesforce","metadata":{"isApplicationScoped":false,"isMachineScoped":false,"isBuiltin":false,"installedTimestamp":1775797119817,"pinned":false,"source":"gallery","id":"e51a0546-dfbb-4d74-9826-207c122ced51","publisherId":"656b996d-3c70-47b4-937e-e77c013faeea","publisherDisplayName":"Salesforce","targetPlatform":"undefined","updated":true,"private":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":