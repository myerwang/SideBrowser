e && agentforceDX:isLiveMode","group":"navigation@-2"},{"command":"sf.agent.combined.view.debugStop","when":"view == sf.agent.combined.view && agentforceDX:sessionActive && agentforceDX:debugMode && agentforceDX:isLiveMode","group":"navigation@-2"},{"command":"sf.agent.test.view.runAll","when":"never && view == sf.agent.test.view","group":"navigation@1"},{"command":"sf.agent.test.view.refresh","when":"view == sf.agent.test.view","group":"navigation@2"},{"command":"sf.agent.test.view.collapseAll","when":"view == sf.agent.test.view","group":"navigation@3"},{"command":"sf.agent.test.view.toggleGeneratedData.on","when":"view == sf.agent.test.view && agentforceDX:showGeneratedData","group":"navigation@4"},{"command":"sf.agent.test.view.toggleGeneratedData.off","when":"view == sf.agent.test.view && !agentforceDX:showGeneratedData","group":"navigation@4"}],"view/item/context":[{"command":"sf.agent.test.view.runTest","when":"view == sf.agent.test.view && viewItem =~ /agentTestGroup/","group":"inline"},{"command":"sf.agent.test.view.goToTestResults","when":"view == sf.agent.test.view && viewItem =~ /(agentTest|agentTestGroup)(_Pass|_Skip|\\b)/"}],"editor/context":[{"command":"salesforcedx-vscode-agents.validateAgent","when":"resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/","group":"agent@1"},{"command":"salesforcedx-vscode-agents.previewAgent","when":"resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/","group":"agent@1"},{"command":"salesforcedx-vscode-agents.publishAgent","when":"resourcePath =~ /aiAuthoringBundles\\/.*\\.agent$/","group":"agent@1"},{"command":"salesforcedx-vscode-agents.activateAgent","when":"resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.*\\.genAiPlannerBundle$/ || resourceFilename =~ /.*\\.botVersion-meta\\.xml/ || explorerResourceIsFolder && resourcePath =~ /bots\\/|botVersions\\//","group":"agent@1"},{"command":"salesforcedx-vscode-agents.deactivateAgent","when":"resourceFilename =~ /.*\\.bot-meta\\.xml/ || resourceFilename =~ /.